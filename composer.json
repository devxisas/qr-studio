{
    "name": "devxisas/laravel-qrcode",
    "description": "A QR code generator package for Laravel.",
    "keywords": [
        "laravel",
        "qrcode",
        "qr-code",
        "generator",
        "devxisas"
    ],
    "homepage": "https://github.com/devxisas/laravel-qrcode",
    "license": "MIT",
    "authors": [
        {
            "name": "Elmer Sorto",
            "email": "elmer@devxi.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-gd": "*",
        "bacon/bacon-qr-code": "^3.0",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0|^14.0"
    },
    "require-dev": {
        "laravel/pint": "^1.13",
        "nunomaduro/collision": "^7.0|^8.0",
        "larastan/larastan": "^3.9",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "suggest": {
        "ext-imagick": "Required for PNG format generation."
    },
    "autoload": {
        "psr-4": {
            "Devxisas\\LaravelQrCode\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Devxisas\\LaravelQrCode\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:unit": "vendor/bin/pest tests/Unit",
        "test:feature": "vendor/bin/pest tests/Feature",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "format:check": "vendor/bin/pint --check"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Devxisas\\LaravelQrCode\\LaravelQrCodeServiceProvider"
            ],
            "aliases": {
                "QrCode": "Devxisas\\LaravelQrCode\\Facades\\QrCode"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}